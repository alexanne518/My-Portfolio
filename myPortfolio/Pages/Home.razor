@page "/"

<style>
    /* 1. Force the page container to fill the entire screen */
    .page {
        display: block !important;
        background-color: #0b0f1a !important;
        margin: 0 !important;
        padding: 0 !important;
    }

    main {
        margin-left: 0 !important;
        width: 100% !important;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .content {
        padding: 0 !important;
        max-width: 100% !important;

    }

    .top-row, .sidebar {
        display: none !important;
    }
</style>
<div class="bg-[#0b0f1a] min-h-screen text-slate-200 selection:bg-fuchsia-500/30">
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden border-b border-white/5 bg-[#0b0f1a]">

        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(17,24,39,0)_0%,rgba(11,15,26,1)_100%)]"></div>

            @* grid *@
            <div class="absolute inset-0 opacity-[0.15]"
                 style="background-image: linear-gradient(#334155 1px, transparent 1px), linear-gradient(90deg, #334155 1px, transparent 1px); background-size: 50px 50px;">
            </div>

            @* moving light behind background *@
            <div class="absolute top-[-10%] left-[-5%] w-[600px] h-[600px] bg-fuchsia-600/20 blur-[130px] rounded-full animate-pulse"></div>
            <div class="absolute bottom-[-10%] right-[-5%] w-[500px] h-[500px] bg-cyan-500/10 blur-[130px] rounded-full"></div>
        </div>

        @* main content *@
        <div class="relative z-10 max-w-6xl mx-auto px-6">
            <div class="flex flex-col items-center">

                @* status Badge *@
                <div class="group cursor-default mb-10 px-5 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-xl transition-all hover:border-fuchsia-500/40">
                    <div class="flex items-center gap-3">
                        <div class="flex h-2 w-2 relative">
                            <div class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></div>
                            <div class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></div>
                        </div>
                        <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-slate-300">
                            System Status: <span class="text-emerald-400">Available for Summer '26 Internships</span>
                        </span>
                    </div>
                </div>

                <div class="text-center space-y-4">
                    <h2 class="text-fuchsia-500 font-mono tracking-[0.5em] uppercase text-sm mb-2 animate-fade-in">Computer Science student</h2>

                    <h1 class="text-7xl md:text-[120px] font-black leading-[0.85] tracking-tighter text-white">
                        ALEXANNE <br />
                        <span class="relative">
                            <span class="text-transparent bg-clip-text bg-gradient-to-r from-fuchsia-500 via-violet-400 to-cyan-400">FORTIN</span>
                            <div class="absolute -bottom-2 left-0 w-full h-[6px] bg-gradient-to-r from-fuchsia-500/50 to-transparent blur-sm"></div>
                        </span>
                    </h1>
                </div>

                @* desc *@
                <div class="mt-12 max-w-2xl text-center">
                    <p class="text-xl md:text-2xl text-slate-400 leading-relaxed font-light">
                        Hello, I am a student in my final semester <span class="text-white font-medium border-b border-emerald-500/50">looking for an internship</span> that will allow me to get my diploma. <br />
                        Learning and practicing <span class="text-white font-medium border-b border-emerald-500/50">programming</span> to expande and explore more feilds in <span class="text-white font-medium">Full-Stack development</span>.
                    </p>
                </div>

                
            </div>
        </div>

        <div class="absolute bottom-10 left-10 hidden xl:block">
            <div class="flex flex-col gap-2 opacity-20 font-mono text-[10px] text-slate-500">
                <p>> KOTLIN_INIT_SUCCESS</p>
                <p>> CLOUD_NODE_STABLE</p>
                <p>> MINING_ENV_SYNCED</p>
            </div>
        </div>
    </section>

    <div id="skills" class="py-24 max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">

            <div class="flex flex-col gap-8">
                @* languages *@
                <div class="group p-8 rounded-[2.5rem] bg-slate-900/40 border border-white/5 backdrop-blur-xl transition-all hover:border-fuchsia-500/30">
                    <h3 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
                        <span class="w-8 h-[1px] bg-fuchsia-500"></span> Languages
                    </h3>
                    <ul class="grid grid-cols-2 gap-4 text-slate-400">
                        <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-fuchsia-500"></div> C# </li>
                        <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-fuchsia-500"></div> Java</li>
                        <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-fuchsia-500"></div> Swift</li>
                        <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-fuchsia-500"></div> PHP</li>
                        <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-fuchsia-500"></div> Orcale & SQL & Firebase</li>
                        <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-fuchsia-500"></div> HTML & CSS & BootStrap & javascript</li>
                    </ul>
                </div>

                @* fameowrks *@
                <div class="group p-8 rounded-[2.5rem] bg-slate-900/40 border border-white/5 backdrop-blur-xl transition-all hover:border-violet-500/30">
                    <h3 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
                        <span class="w-8 h-[1px] bg-violet-500"></span> Frameworks
                    </h3>
                    <ul class="grid grid-cols-2 gap-4 text-slate-400">
                        <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-violet-500"></div> ASP.NET Core</li>
                        <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-violet-500"></div> .NET MAUI</li>
                        <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-violet-500"></div> Entity</li>
                        <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-violet-500"></div> Blazor</li>
                    </ul>
                </div>
            </div>

            @* what im learning *@
            <div class="group p-8 rounded-[2.5rem] bg-gradient-to-br from-slate-900/80 to-slate-950 border border-cyan-500/20 transition-all hover:border-cyan-500/50">
                <div class="flex justify-between items-start mb-8">
                    <h3 class="text-2xl font-bold text-cyan-400">Next Horizons</h3>
                    <span class="px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-[10px] font-mono text-cyan-500 animate-pulse">
                        SYSTEMS_UPDATING
                    </span>
                </div>

                <div class="space-y-4">
                    <div class="p-5 bg-white/5 rounded-2xl border border-white/5 hover:bg-white/10 transition-colors">
                        <p class="text-[10px] text-cyan-500 font-black uppercase tracking-widest mb-1">Cloud Architecture</p>
                        <p class="text-lg font-bold text-white">AWS Ecosystem</p>
                    </div>

                    <div class="p-5 bg-white/5 rounded-2xl border border-white/5 hover:bg-white/10 transition-colors">
                        <p class="text-[10px] text-cyan-500 font-black uppercase tracking-widest mb-1">Mobile Native</p>
                        <p class="text-lg font-bold text-white">Kotlin Development</p>
                    </div>

                    <div class="p-5 bg-white/5 rounded-2xl border border-white/5 hover:bg-white/10 transition-colors">
                        <p class="text-[10px] text-cyan-500 font-black uppercase tracking-widest mb-1">DevOps & Systems</p>
                        <p class="text-lg font-bold text-white">Docker Containerization</p>
                    </div
                </div>
            </div>

        </div>
    </div>

    @* title *@
